)
) +
labs(
title = "Risk Tier Transition Heatmap",
x = "Previous Tier",
y = "Current Tier",
fill = "Risk Movement"
) +
facet_grid(. ~ year_pair) +     # ← THIS adds 2022→2023 and 2023→2024 panels
theme_minimal() +
theme(axis.text.x = element_text(angle = 45, hjust = 1))
ggplot(transition_matrix,
aes(x = previous_risk_tier,
y = risk_tier,
fill = change)) +
geom_tile() +
geom_text(aes(label = n), color = "white", size = 5) +
scale_fill_manual(
values = c(
"Increased" = "firebrick",
"Decreased" = "steelblue",
"No Change" = "gray50"
)
) +
labs(
title = "Risk Tier Transition Heatmap",
x = "Previous Tier",
y = "Current Tier",
fill = "Risk Movement"
) +
facet_grid(. ~ year_pair) +     # ← THIS adds 2022→2023 and 2023→2024 panels
theme_minimal() +
theme(axis.text.x = element_text(angle = 45, hjust = 1))
transition_matrix <- transition_matrix %>%
mutate(
year_pair = paste(previous_year, "→", Year)
) %>%
count(previous_risk_tier, risk_tier, change, year_pair)
ggplot(transition_matrix,
aes(x = previous_risk_tier,
y = risk_tier,
fill = change)) +
