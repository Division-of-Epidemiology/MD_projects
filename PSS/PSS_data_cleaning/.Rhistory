library(dplyr)
library(tidyr)
library(ggplot2)
getwd()
suicide_data <- read.csv("C:/Users/mdickson/OneDrive - Metro Nashville Gov/Desktop/CVS_Files/suicide_ME_2026")
suicide_data <- read.csv("C:/Users/mdickson/OneDrive - Metro Nashville Gov/Desktop/CVS_Files/suicide_ME_2026.csv")
View(suicide_data)
##Age grouping##
breaks <- c(17, 24, 34, 44, 54, 64, Inf)
labels <- c("0-18", "18-24", "25-34", "35-44", "45-54", "55-64", "65+")
suicide_data <- cut(suicide_data,
breaks=breaks,
labels=labels,
right=TRUE,
ordered_result = TRUE)
View(suicide_data)
##Age grouping##
suicide_data[, Age_group := as.numeric(gsub("[^0-9]", "", Age))]
## Age grouping ##
suicide_data[, Age_group := as.numeric(gsub("[^0-9]", "", Age))]
## Age grouping ##
suicide_data <- suicide_data %>%
mutate(
Age_group = as.numeric(gsub("[^0-9]", "", Age)),
Age_group = cut(
Age_group,
breaks = c(-Inf, 18, 24, 34, 44, 54, 64, Inf),
labels = c("0-18", "18-24", "25-34", "35-44", "45-54", "55-64", "65+"),
right = TRUE,
ordered_result = TRUE
)
)
View(suicide_data)
## Age grouping ##
suicide_data <- suicide_data %>%
mutate(
Age_group = as.numeric(gsub("[^0-9]", "", Age)),
Age_group = cut(
Age_group,
breaks = c(-Inf, 18, 24, 34, 44, 54, 64, Inf),
labels = c("0-18", "18-24", "25-34", "35-44", "45-54", "55-64", "65+"),
right = TRUE,
ordered_result = TRUE
),
Year = as.numeric(format(as.Date(DOD, format = "%m/%d/%Y"), "%Y"))
)
View(suicide_data)
HR_data <- read.csv("C:/Users/mdickson/OneDrive - Metro Nashville Gov/Desktop/CVS_Files/Heat_related_2226.csv")
triage_labels <- c("1 - Resuscitation", "2 - Emergent", "3 - Urgent", "4 - Less Urgent", "5 - Non-Urgent")
HR_clean <- HR_data %>%
select(PIN, Date, Zipcode, Sex, Age, c_race, Chief_Complaint_Combo, CCDDCategory_flat) %>%
mutate(Initial_Acuity_Combo = as.integer(sub("^(\\d+).*", "\\1", Initial_Acuity_Combo)),
Initial_Acuity_Combo = factor(recode(Initial_Acuity_Combo,
`1` = "1 - Resuscitation",
`2` = "2 - Emergent",
`3` = "3 - Urgent",
`4` = "4 - Less Urgent",
`5` = "5 - Non-Urgent"
), levels=triage_labels, ordered=TRUE),
Housing_status = case_when(
grepl("Persons Experiencing Homelessness", CCDDCategory_flat, ignore.case = TRUE) ~ "Unhoused",
TRUE ~ "Other"
))
