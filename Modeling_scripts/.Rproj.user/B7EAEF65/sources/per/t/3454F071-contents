      Max_Decrease_Week = period_data$MMWR_Week_No[which.min(period_data$pct_change)]
    ))
  }
  
  cat("\n=== SIGNIFICANT PERIODS SUMMARY TABLE ===\n")
  print(periods_summary, row.names = FALSE)
  
} else {
