# Line plot showing risk score trends for specific zips  (only one zip code right now)
high_movers <- risk_transitions %>%
  group_by(Zip) %>%
  summarise(
    n_changes = sum(changed_status, na.rm = TRUE),
    .groups = "drop"
  ) %>%
  filter(n_changes >= 2) %>%  # Zips that changed multiple times
  pull(Zip)

yearly_risk_classification %>%
  filter(Zip %in% high_movers) %>%
  ggplot(aes(x = Year, y = risk_score, group = Zip, color = Zip)) +
  geom_line(size = 1) +
  geom_point(size = 2) +
  geom_hline(yintercept = 3, linetype = "dashed", color = "red") +
  labs(title = "Risk Score Trajectories for Volatile Zip Codes",
       subtitle = "Dashed line = High Risk threshold",
       y = "Risk Score (0-7)") +
  theme_minimal()

# Classify zip codes by their overall trajectory
zip_trajectory <- yearly_risk_classification %>%
  group_by(Zip) %>%
  summarise(
    start_risk_score = first(risk_score),
    end_risk_score = last(risk_score),
    mean_risk_score = mean(risk_score),
    always_high_risk = all(high_risk_zip),
    always_low_risk = all(!high_risk_zip),
    became_high_risk = first(!high_risk_zip) & last(high_risk_zip),
    improved = first(high_risk_zip) & last(!high_risk_zip),
    volatile = n_distinct(risk_tier) >= 3,
    .groups = "drop"
  ) %>%
  mutate(
    trajectory_type = case_when(
      always_high_risk ~ "Persistently High Risk",
      always_low_risk ~ "Persistently Low Risk",
      became_high_risk ~ "Deteriorating",
      improved ~ "Improving",
      volatile ~ "Volatile",
      TRUE ~ "Stable"
    )
  )

table(zip_trajectory$trajectory_type)

# See which zips are deteriorating
zip_trajectory %>%
  filter(trajectory_type == "Deteriorating") %>%
  left_join(
    yearly_risk_classification %>% filter(Year == max(Year)),
    by = "Zip"
  ) %>%
  select(Zip, start_risk_score, end_risk_score, 
         zip_income, zip_narcan, zip_violent, zip_od_count)




